# ── GCP / Vertex AI ─────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=my-gcp-project
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-pro

# ── CloudSQL (via Cloud SQL Auth Proxy sidecar) ─────────────────────────────
CLOUDSQL_HOST=127.0.0.1
CLOUDSQL_PORT=5432
CLOUDSQL_DATABASE=terraform_driftguard
CLOUDSQL_USER=terraform_driftguard
CLOUDSQL_PASSWORD=change-me   # source from Secret Manager in prod

# ── Jira (Cloud, REST API v3 + ADF) ─────────────────────────────────────────
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=automation@your-domain.com
JIRA_API_TOKEN=change-me      # source from Secret Manager
JIRA_PROJECT_KEY=PROJ
JIRA_API_VERSION=3            # 3 = Cloud (ADF). 2 = Server/DC (wiki markup)
JIRA_ACLI_PATH=acli
JIRA_TIMEOUT_SECONDS=10

# ── GitHub (api/v3 Enterprise or api.github.com) ────────────────────────────
GITHUB_API_BASE=https://api.github.com   # or https://ghe.corp/api/v3
GITHUB_REPO_OWNER=my-org
GITHUB_REPO_NAME=terraform-modules
GITHUB_DEFAULT_BRANCH=main
GITHUB_TIMEOUT_SECONDS=20

# Auth mode: "pat" or "app"
GITHUB_AUTH_MODE=pat
# PAT mode:
GITHUB_PAT=ghp_change-me
# GitHub App mode:
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/var/secrets/github-app/private-key.pem

# ── Pipeline ────────────────────────────────────────────────────────────────
CAPTURE_ENABLED=false
CAPTURE_DIR=/tmp/terraform-driftguard-eval
SKILLS_ROOT=skills
GCP_RELEASE_FEED_URL=https://cloud.google.com/feeds/gcp-release-notes.xml
TERRAFORM_MODULE_PATH=modules
ARTIFACT_DIR=/tmp/terraform-driftguard-artifacts
LOG_LEVEL=INFO

# ── Accuracy / optimisation features ──────────────────────────────────────
# Tiered model routing: cheaper model for parsing/bucketing agents
VERTEX_MODEL_FAST=gemini-2.5-flash
VERTEX_MODEL_JUDGE=gemini-2.5-flash

# Self-correcting validate->plan loop
TERRAFORM_MAX_RETRIES=3

# Judge/critic pass
JUDGE_ENABLED=true
JUDGE_MIN_SCORE=70

# TTL cache for provider schema + registry lookups (seconds; 1 day default)
CACHE_TTL_SECONDS=86400

# Embedding-based relevance filter (skips irrelevant releases early)
RELEVANCE_FILTER_ENABLED=true

# Classification batch size (avoids large-batch JSON parse errors)
CLASSIFICATION_BATCH_SIZE=5

# ── Skills source (single source of truth) ─────────────────────────────────
# local  = read skills from the image / mounted volume (default)
# github = read skills + product manifests from the GitHub repo at runtime,
#          so adding/editing a skill needs NO rebuild or redeploy.
SKILLS_SOURCE=local
# When SKILLS_SOURCE=github (defaults fall back to the module repo + main):
SKILLS_REPO_OWNER=
SKILLS_REPO_NAME=
SKILLS_REPO_REF=
SKILLS_REPO_PATH=skills
# Runtime cache TTL for fetched skills/manifests (seconds; 0 disables caching).
SKILLS_CACHE_TTL=300
