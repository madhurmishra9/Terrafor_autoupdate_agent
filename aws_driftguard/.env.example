# ── AWS DriftGuard environment ─────────────────────────────────────────────
# Runs natively on AWS: Bedrock + RDS + Secrets Manager + ECS/EKS.

# AWS / Bedrock
AWS_REGION=us-east-1
ORCHESTRATION_MODE=converse           # converse (runnable) | agents (managed Bedrock Agents)
BEDROCK_MODEL=anthropic.claude-sonnet-4-6-20260514-v1:0
BEDROCK_MODEL_FAST=anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_JUDGE=anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_MAX_TOKENS=4096

# Managed Bedrock Agents (only when ORCHESTRATION_MODE=agents)
BEDROCK_SUPERVISOR_AGENT_ID=
BEDROCK_SUPERVISOR_AGENT_ALIAS_ID=TSTALIASID

# RDS Postgres (password via Secrets Manager in prod)
RDS_HOST=127.0.0.1
RDS_PORT=5432
RDS_DATABASE=aws_driftguard
RDS_USER=driftguard
RDS_PASSWORD=
RDS_PASSWORD_SECRET_ID=

# Release feed + Terraform
RELEASE_FEED_URL=https://aws.amazon.com/about-aws/whats-new/recent/feed/
TERRAFORM_MODULE_PATH=modules

# Jira (token via Secrets Manager in prod)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=bot@your-domain.com
JIRA_API_TOKEN=
JIRA_API_TOKEN_SECRET_ID=
JIRA_PROJECT_KEY=DRIFT
JIRA_API_VERSION=3
JIRA_ACLI_PATH=acli
JIRA_TIMEOUT_SECONDS=10

# GitHub (PAT via Secrets Manager, or App)
GITHUB_API_BASE=https://api.github.com
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=terraform-modules
GITHUB_DEFAULT_BRANCH=main
GITHUB_AUTH_MODE=pat
GITHUB_PAT=
GITHUB_PAT_SECRET_ID=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_SECRET_ID=

# Features
TERRAFORM_MAX_RETRIES=3
JUDGE_ENABLED=true
JUDGE_MIN_SCORE=70
CACHE_TTL_SECONDS=86400
RELEVANCE_FILTER_ENABLED=true
CLASSIFICATION_BATCH_SIZE=5
CAPTURE_ENABLED=false

# ── Skills source (single source of truth) ─────────────────────────────────
# local  = read skills from the image / mounted volume (default)
# github = read skills + product manifests from the GitHub repo at runtime,
#          so adding/editing a skill needs NO rebuild or redeploy.
SKILLS_SOURCE=local
# When SKILLS_SOURCE=github (defaults fall back to the module repo + main):
SKILLS_REPO_OWNER=
SKILLS_REPO_NAME=
SKILLS_REPO_REF=
SKILLS_REPO_PATH=skills
# Runtime cache TTL for fetched skills/manifests (seconds; 0 disables caching).
SKILLS_CACHE_TTL=300
