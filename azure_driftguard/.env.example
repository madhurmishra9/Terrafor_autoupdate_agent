# ── Azure DriftGuard environment ───────────────────────────────────────────
# Runs natively on Azure: Azure OpenAI + Azure SQL + Key Vault + AKS + AI Agent Service.

ORCHESTRATION_MODE=sdk                 # sdk (runnable) | connected (managed AI Agent Service)

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_KEY_SECRET=aoai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_FAST=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_JUDGE=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_MAX_TOKENS=4096

# Azure AI Agent Service (only when ORCHESTRATION_MODE=connected)
AZURE_AI_PROJECT_ENDPOINT=

# Key Vault (secret resolution)
AZURE_KEYVAULT_URL=https://your-kv.vault.azure.net/

# Azure SQL (password via Key Vault in prod)
AZURE_SQL_SERVER=your-sql.database.windows.net
AZURE_SQL_PORT=1433
AZURE_SQL_DATABASE=azure_driftguard
AZURE_SQL_USER=driftguard
AZURE_SQL_PASSWORD=
AZURE_SQL_PASSWORD_SECRET=sql-password
AZURE_SQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# Release feed + Terraform
RELEASE_FEED_URL=https://www.microsoft.com/releasecommunications/api/v2/azure/rss
TERRAFORM_MODULE_PATH=modules

# Jira (token via Key Vault in prod)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=bot@your-domain.com
JIRA_API_TOKEN=
JIRA_API_TOKEN_SECRET=jira-token
JIRA_PROJECT_KEY=DRIFT
JIRA_API_VERSION=3
JIRA_ACLI_PATH=acli
JIRA_TIMEOUT_SECONDS=10

# GitHub (PAT via Key Vault, or App)
GITHUB_API_BASE=https://api.github.com
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=terraform-modules
GITHUB_DEFAULT_BRANCH=main
GITHUB_AUTH_MODE=pat
GITHUB_PAT=
GITHUB_PAT_SECRET=github-pat
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_SECRET=

# Features
TERRAFORM_MAX_RETRIES=3
JUDGE_ENABLED=true
JUDGE_MIN_SCORE=70
CACHE_TTL_SECONDS=86400
RELEVANCE_FILTER_ENABLED=true
CLASSIFICATION_BATCH_SIZE=5
CAPTURE_ENABLED=false

# ── Skills source (single source of truth) ─────────────────────────────────
# local  = read skills from the image / mounted volume (default)
# github = read skills + product manifests from the GitHub repo at runtime,
#          so adding/editing a skill needs NO rebuild or redeploy.
SKILLS_SOURCE=local
# When SKILLS_SOURCE=github (defaults fall back to the module repo + main):
SKILLS_REPO_OWNER=
SKILLS_REPO_NAME=
SKILLS_REPO_REF=
SKILLS_REPO_PATH=skills
# Runtime cache TTL for fetched skills/manifests (seconds; 0 disables caching).
SKILLS_CACHE_TTL=300
